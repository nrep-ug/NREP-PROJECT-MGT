# Appwrite Configuration
# Get these values from your Appwrite Console (https://cloud.appwrite.io)
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your-project-id-here
NEXT_PUBLIC_APPWRITE_DATABASE_ID=pms_db

# Server-only Appwrite Configuration
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your-project-id-here
APPWRITE_API_KEY=your-server-api-key-here
APPWRITE_DATABASE_ID=pms_db

# Storage Buckets
# These will be auto-created when you run: npm run setup:collections
APPWRITE_BUCKET_DOCS=pms-project-docs
APPWRITE_BUCKET_VERSIONS=pms-doc-versions
NEXT_PUBLIC_APPWRITE_BUCKET_DOCS=pms-project-docs
NEXT_PUBLIC_APPWRITE_BUCKET_VERSIONS=pms-doc-versions

# Collections
# All collection IDs used by the application
NEXT_PUBLIC_APPWRITE_COL_ORGANIZATIONS=pms_organizations
NEXT_PUBLIC_APPWRITE_COL_USERS=pms_users
NEXT_PUBLIC_APPWRITE_COL_CLIENTS=pms_clients
NEXT_PUBLIC_APPWRITE_COL_PROJECTS=pms_projects
NEXT_PUBLIC_APPWRITE_COL_MILESTONES=pms_milestones
NEXT_PUBLIC_APPWRITE_COL_TASKS=pms_tasks
NEXT_PUBLIC_APPWRITE_COL_TASK_ASSIGNMENTS=pms_task_assignments
NEXT_PUBLIC_APPWRITE_COL_TASK_COMMENTS=pms_task_comments
NEXT_PUBLIC_APPWRITE_COL_TIMESHEETS=pms_timesheets
NEXT_PUBLIC_APPWRITE_COL_TIMESHEET_ENTRIES=pms_timesheet_entries
NEXT_PUBLIC_APPWRITE_COL_DOCUMENTS=pms_documents
NEXT_PUBLIC_APPWRITE_COL_DOCUMENT_FOLDERS=pms_document_folders
NEXT_PUBLIC_APPWRITE_COL_DOCUMENT_VERSIONS=pms_document_versions
NEXT_PUBLIC_APPWRITE_COL_EMBEDS=pms_embeds
NEXT_PUBLIC_APPWRITE_COL_FX_RATES=pms_fx_rates
NEXT_PUBLIC_APPWRITE_COL_PROJECT_COMPONENTS=pms_project_components
NEXT_PUBLIC_APPWRITE_COL_PROJECT_ROLES=pms_project_roles

# Organization Configuration
# These will be auto-generated when you run: npm run setup
# Leave commented out - the setup wizard will fill these in
# ORG_NAME=Your Organization Name
# ORG_TEAM_ID=org_your_organization

# Teams Bootstrap
# Update this URL for production deployments
APPWRITE_INVITE_REDIRECT=http://localhost:3000/auth/callback

# Email Configuration (for notifications)
# SMTP settings for sending email notifications
# For Gmail: Use App Password (https://support.google.com/accounts/answer/185833)
# Leave blank in development to log emails instead of sending
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=NREP PMS <noreply@nrep.com>

# Application URL (required for email links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Internal API Secret (used to protect notification endpoints from external abuse)
# Generate a random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_API_SECRET=
